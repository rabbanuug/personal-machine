# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Claude Code project-local settings (not dotfiles)
.claude/

# ── Dotfiles: secrets and machine-specific state ──────────────────────────────

# Claude Code credentials — NEVER commit
dotfiles/claude/.credentials.json
**/claude/.credentials.json

# Claude Code: ephemeral and machine-specific state
dotfiles/claude/backups/
dotfiles/claude/cache/
dotfiles/claude/downloads/
dotfiles/claude/file-history/
dotfiles/claude/history.jsonl
dotfiles/claude/mcp-needs-auth-cache.json
dotfiles/claude/plans/
dotfiles/claude/projects/
dotfiles/claude/session-env/
dotfiles/claude/sessions/
dotfiles/claude/shell-snapshots/

# Claude plugins: marketplace contents are auto-fetched, only track the registry file
dotfiles/claude/plugins/marketplaces/

# Git credential helpers write tokens here
dotfiles/git/.git-credentials
dotfiles/git/.gitconfig-work

# SSH private keys
dotfiles/ssh/id_*
!dotfiles/ssh/*.pub
!dotfiles/ssh/config.example

# Backup files created by install scripts
*.bak.*

# Environment files
.env
.env.*
!.env.example
